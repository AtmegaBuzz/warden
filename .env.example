# Warden Environment Variables

# Sepolia RPC (Alchemy, Infura, or public)
RPC_URL=https://rpc.sepolia.org

# Deployer private key (NO 0x prefix for hardhat, WITH 0x for viem)
DEPLOYER_PRIVATE_KEY=

# Deployed PolicyDelegate contract address (after running deploy script)
POLICY_DELEGATE_ADDRESS=

# Real Sepolia USDT — official Tether deployment
SEPOLIA_USDT_ADDRESS=0x7169D38820dfd117C3FA1f22a697dBA58d90BA06

# Agent private keys (for demo)
AGENT_1_PRIVATE_KEY=
AGENT_2_PRIVATE_KEY=
AGENT_3_PRIVATE_KEY=

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=

# ERC-8004 Registry addresses (Sepolia)
ERC8004_IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8004_REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# API server port
API_PORT=3001
