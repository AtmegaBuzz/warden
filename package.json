{
  "name": "warden",
  "version": "0.3.0",
  "private": true,
  "description": "EIP-7702 Policy Enforcement for AI Agent Wallets — powered by Tether WDK",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/dashboard",
    "dev:api": "npm run dev --workspace=packages/api-server",
    "dev:all": "npm run dev:api & npm run dev",
    "test": "npm run test:contracts && npm run test:engine",
    "test:contracts": "npm run test --workspace=packages/contracts",
    "test:engine": "npm run test --workspace=packages/policy-engine",
    "compile": "npm run compile --workspace=packages/contracts",
    "deploy:sepolia": "npm run deploy:sepolia --workspace=packages/contracts",
    "demo": "npx tsx demo/multi-agent-demo.ts",
    "mcp": "npm run start --workspace=packages/mcp-server"
  }
}
